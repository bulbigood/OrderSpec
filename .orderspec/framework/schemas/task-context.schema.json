{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OrderSpec Task Context",
  "description": "Machine-readable per-task read whitelist owned by tasks.md.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "tasks"],
  "properties": {
    "version": {
      "const": 1
    },
    "tasks": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["read", "target_state"],
        "properties": {
          "read": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "target_state": {
            "enum": ["new", "mod", "del"]
          },
          "contract_refs": {
            "description": "Optional exact spec IDs needed by this task in addition to coverage refs on the task line.",
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^(REQ|NFR|SC|INV|EDGE|UJ|AC|Q|ASM|DEC|IF)-[0-9]{3}$"
            }
          }
        }
      }
    }
  }
}

{
  "version": 2,
  "resources": {
    "framework.rules": {
      "path": ".orderspec/framework/orderspec-rules.md",
      "kind": "framework_rules",
      "reason": "global framework rules",
      "usage": "apply",
      "authority": "framework"
    },
    "protocol.tooling": {
      "path": ".orderspec/framework/protocols/tooling-protocol.md",
      "kind": "protocol",
      "reason": "library and tooling documentation verification protocol",
      "usage": "apply",
      "authority": "framework"
    },
    "protocol.sub_agent_execution": {
      "path": ".orderspec/framework/protocols/sub-agent-execution.md",
      "kind": "protocol",
      "reason": "isolated task packet and worker result protocol",
      "usage": "apply",
      "authority": "framework"
    },
    "protocol.sub_agent_rules": {
      "path": ".orderspec/framework/protocols/sub-agent-rules.md",
      "kind": "protocol",
      "reason": "worker selection, readiness, and configuration ownership",
      "usage": "apply",
      "authority": "framework"
    },
    "schema.frontmatter": {
      "path": ".orderspec/framework/schemas/frontmatter.yml",
      "kind": "schema",
      "reason": "artifact frontmatter schema",
      "usage": "parse",
      "authority": "framework"
    },
    "schema.artifacts": {
      "path": ".orderspec/framework/schemas/artifacts.yml",
      "kind": "schema",
      "reason": "OrderSpec artifact schema",
      "usage": "parse",
      "authority": "framework"
    },
    "schema.lifecycle": {
      "path": ".orderspec/framework/schemas/lifecycle.yml",
      "kind": "schema",
      "reason": "artifact lifecycle schema",
      "usage": "parse",
      "authority": "framework"
    },
    "schema.traceability": {
      "path": ".orderspec/framework/schemas/traceability.yml",
      "kind": "schema",
      "reason": "traceability and stable ID schema",
      "usage": "parse",
      "authority": "framework"
    },
    "project.constitution": {
      "path": ".orderspec/contracts/constitution.md",
      "kind": "project_contract",
      "reason": "project governance",
      "usage": "constrain",
      "authority": "project"
    },
    "project.stack": {
      "path": ".orderspec/contracts/stack.md",
      "kind": "project_contract",
      "reason": "project stack contract",
      "usage": "constrain",
      "authority": "project"
    },
    "project.architecture": {
      "path": ".orderspec/contracts/architecture.md",
      "kind": "project_contract",
      "reason": "project architecture contract",
      "usage": "constrain",
      "authority": "project"
    },
    "project.conventions": {
      "path": ".orderspec/contracts/conventions.md",
      "kind": "project_contract",
      "reason": "project conventions contract",
      "usage": "constrain",
      "authority": "project"
    },
    "config.tooling": {
      "path": ".orderspec/config/tooling.json",
      "kind": "tooling_config",
      "reason": "tooling and documentation verification policy override",
      "usage": "parse",
      "authority": "operator_config"
    },
    "state.agents": {
      "path": ".orderspec/state/agents.json",
      "kind": "runtime_state",
      "reason": "multi-agent configuration and sync state",
      "usage": "parse",
      "authority": "runtime"
    },
    "schema.agents_state": {
      "path": ".orderspec/framework/schemas/agents-state.schema.json",
      "kind": "schema",
      "reason": "agents state validation schema",
      "usage": "parse",
      "authority": "framework"
    },
    "schema.task_context": {
      "path": ".orderspec/framework/schemas/task-context.schema.json",
      "kind": "schema",
      "reason": "per-task worker context schema",
      "usage": "parse",
      "authority": "framework"
    },
    "framework.meta": {
      "path": ".orderspec/orderspec.json",
      "kind": "framework_config",
      "reason": "framework version and schema versions",
      "usage": "parse",
      "authority": "framework"
    },
    "schema.orderspec_meta": {
      "path": ".orderspec/framework/schemas/orderspec-meta.schema.json",
      "kind": "schema",
      "reason": "orderspec.json validation schema",
      "usage": "parse",
      "authority": "framework"
    },
    "framework.identifiers": {
      "path": ".orderspec/framework/orderspec-identifiers.md",
      "kind": "framework_rules",
      "reason": "stable identifier prefixes and glossary",
      "usage": "apply",
      "authority": "framework"
    }
  },
  "groups": {
    "artifact.schemas": [
      {
        "ref": "schema.frontmatter"
      },
      {
        "ref": "schema.artifacts"
      },
      {
        "ref": "schema.lifecycle"
      },
      {
        "ref": "schema.traceability"
      }
    ],
    "project.contracts": [
      {
        "ref": "project.constitution"
      },
      {
        "ref": "project.stack"
      },
      {
        "ref": "project.architecture"
      },
      {
        "ref": "project.conventions"
      }
    ],
    "tooling.optional": [
      {
        "ref": "config.tooling"
      }
    ],
    "runtime.agents": [
      {
        "ref": "state.agents"
      }
    ]
  },
  "defaults": {
    "required": [
      {
        "ref": "framework.rules"
      },
      {
        "ref": "framework.identifiers"
      }
    ]
  },
  "commands": {
    "order.bootstrap": {
      "read_if_exists": [
        {
          "group": "project.contracts"
        },
        {
          "group": "runtime.agents"
        }
      ]
    },
    "order.spec": {
      "required": [
        {
          "group": "project.contracts"
        }
      ]
    },
    "order.spec-check": {
      "required": [
        {
          "group": "project.contracts"
        }
      ],
      "feature_context": {
        "mode": "required",
        "artifacts": [
          "spec"
        ]
      }
    },
    "order.plan": {
      "required": [
        {
          "group": "project.contracts"
        }
      ],
      "feature_context": {
        "mode": "required",
        "artifacts": [
          "spec"
        ]
      }
    },
    "order.plan-check": {
      "required": [
        {
          "group": "project.contracts"
        }
      ],
      "feature_context": {
        "mode": "required",
        "artifacts": [
          "spec",
          "plan"
        ]
      }
    },
    "order.tasks": {
      "required": [
        {
          "group": "project.contracts"
        },
        {
          "ref": "schema.task_context"
        }
      ],
      "feature_context": {
        "mode": "required",
        "artifacts": [
          "spec",
          "plan"
        ]
      }
    },
    "order.tasks-check": {
      "required": [
        {
          "group": "project.contracts"
        },
        {
          "ref": "schema.task_context"
        }
      ],
      "feature_context": {
        "mode": "required",
        "artifacts": [
          "spec",
          "plan",
          "tasks"
        ]
      }
    },
    "order.code": {
      "required": [
        {
          "group": "project.contracts"
        },
        {
          "ref": "protocol.sub_agent_execution"
        },
        {
          "ref": "protocol.sub_agent_rules"
        },
        {
          "ref": "schema.task_context"
        }
      ],
      "feature_context": {
        "mode": "required",
        "artifacts": [
          "plan",
          "tasks"
        ]
      }
    },
    "order.code-check": {
      "required": [
        {
          "group": "project.contracts"
        }
      ],
      "feature_context": {
        "mode": "required",
        "artifacts": [
          "spec",
          "plan",
          "tasks"
        ]
      }
    }
  }
}

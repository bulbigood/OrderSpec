{
  "version": 2,
  "resources": {
    "framework.rules": {
      "path": ".orderspec/framework/orderspec-rules.md",
      "kind": "framework_rules",
      "reason": "global framework rules",
      "usage": "apply",
      "authority": "framework"
    },
    "protocol.tooling": {
      "path": ".orderspec/framework/protocols/tooling-protocol.md",
      "kind": "protocol",
      "reason": "library and tooling documentation verification protocol",
      "usage": "apply",
      "authority": "framework"
    },
    "protocol.sub_agent_execution": {
      "path": ".orderspec/framework/protocols/sub-agent-execution.md",
      "kind": "protocol",
      "reason": "isolated task packet and worker result protocol",
      "usage": "apply",
      "authority": "framework"
    },
    "protocol.worker_execution": {
      "path": ".orderspec/framework/protocols/worker-execution.json",
      "kind": "worker_protocol_template",
      "reason": "canonical self-contained worker instructions and result contract",
      "usage": "parse",
      "authority": "framework"
    },
    "protocol.environment_block": {
      "path": ".orderspec/framework/protocols/environment-block.md",
      "kind": "protocol",
      "reason": "runtime prerequisite detection, approval, recovery, and fallback",
      "usage": "apply",
      "authority": "framework"
    },
    "protocol.blocking_feedback": {
      "path": ".orderspec/framework/protocols/blocking-feedback.md",
      "kind": "protocol",
      "reason": "persistent cross-command blocker routing and owner intake",
      "usage": "apply",
      "authority": "framework"
    },
    "schema.frontmatter": {
      "path": ".orderspec/framework/schemas/frontmatter.yml",
      "kind": "schema",
      "reason": "artifact frontmatter schema",
      "usage": "parse",
      "authority": "framework"
    },
    "schema.artifacts": {
      "path": ".orderspec/framework/schemas/artifacts.yml",
      "kind": "schema",
      "reason": "OrderSpec artifact schema",
      "usage": "parse",
      "authority": "framework"
    },
    "schema.lifecycle": {
      "path": ".orderspec/framework/schemas/lifecycle.yml",
      "kind": "schema",
      "reason": "artifact lifecycle schema",
      "usage": "parse",
      "authority": "framework"
    },
    "schema.traceability": {
      "path": ".orderspec/framework/schemas/traceability.yml",
      "kind": "schema",
      "reason": "traceability and stable ID schema",
      "usage": "parse",
      "authority": "framework"
    },
    "project.constitution": {
      "path": ".orderspec/contracts/constitution.md",
      "kind": "project_contract",
      "reason": "project governance",
      "usage": "constrain",
      "authority": "project"
    },
    "project.stack": {
      "path": ".orderspec/contracts/stack.md",
      "kind": "project_contract",
      "reason": "project stack contract",
      "usage": "constrain",
      "authority": "project"
    },
    "project.architecture": {
      "path": ".orderspec/contracts/architecture.md",
      "kind": "project_contract",
      "reason": "project architecture contract",
      "usage": "constrain",
      "authority": "project"
    },
    "project.conventions": {
      "path": ".orderspec/contracts/conventions.md",
      "kind": "project_contract",
      "reason": "project conventions contract",
      "usage": "constrain",
      "authority": "project"
    },
    "config.tooling": {
      "path": ".orderspec/config/tooling.json",
      "kind": "tooling_config",
      "reason": "tooling and documentation verification policy override",
      "usage": "parse",
      "authority": "operator_config"
    },
    "config.automation": {
      "path": ".orderspec/config/automation.json",
      "kind": "automation_config",
      "reason": "operator policy for cross-command continuation",
      "usage": "parse",
      "authority": "operator_config"
    },
    "schema.automation_config": {
      "path": ".orderspec/framework/schemas/automation-config.schema.json",
      "kind": "schema",
      "reason": "automation policy configuration schema",
      "usage": "parse",
      "authority": "framework"
    },
    "state.agents": {
      "path": ".orderspec/state/agents.json",
      "kind": "runtime_state",
      "reason": "multi-agent configuration and sync state",
      "usage": "parse",
      "authority": "runtime"
    },
    "schema.agents_state": {
      "path": ".orderspec/framework/schemas/agents-state.schema.json",
      "kind": "schema",
      "reason": "agents state validation schema",
      "usage": "parse",
      "authority": "framework"
    },
    "state.bootstrap": {
      "path": ".orderspec/state/bootstrap.json",
      "kind": "runtime_state",
      "reason": "bootstrap initialization and refine comparison baseline",
      "usage": "parse",
      "authority": "runtime"
    },
    "schema.bootstrap_state": {
      "path": ".orderspec/framework/schemas/bootstrap-state.schema.json",
      "kind": "schema",
      "reason": "bootstrap state validation schema",
      "usage": "parse",
      "authority": "framework"
    },
    "schema.active_feature_state": {
      "path": ".orderspec/framework/schemas/active-feature-state.schema.json",
      "kind": "schema",
      "reason": "canonical active feature runtime state",
      "usage": "parse",
      "authority": "framework"
    },
    "schema.task_context": {
      "path": ".orderspec/framework/schemas/task-context.schema.json",
      "kind": "schema",
      "reason": "per-task worker context schema",
      "usage": "parse",
      "authority": "framework"
    },
    "schema.worker_envelope": {
      "path": ".orderspec/framework/schemas/worker-envelope.schema.json",
      "kind": "schema",
      "reason": "rendered worker envelope schema",
      "usage": "parse",
      "authority": "framework"
    },
    "framework.meta": {
      "path": ".orderspec/orderspec.json",
      "kind": "framework_config",
      "reason": "framework version and schema versions",
      "usage": "parse",
      "authority": "framework"
    },
    "schema.orderspec_meta": {
      "path": ".orderspec/framework/schemas/orderspec-meta.schema.json",
      "kind": "schema",
      "reason": "orderspec.json validation schema",
      "usage": "parse",
      "authority": "framework"
    },
    "framework.identifiers": {
      "path": ".orderspec/framework/orderspec-identifiers.md",
      "kind": "framework_rules",
      "reason": "stable identifier prefixes and glossary",
      "usage": "apply",
      "authority": "framework"
    }
  },
  "groups": {
    "artifact.schemas": [
      {
        "ref": "schema.frontmatter"
      },
      {
        "ref": "schema.artifacts"
      },
      {
        "ref": "schema.lifecycle"
      },
      {
        "ref": "schema.traceability"
      }
    ],
    "project.contracts": [
      {
        "ref": "project.constitution"
      },
      {
        "ref": "project.stack"
      },
      {
        "ref": "project.architecture"
      },
      {
        "ref": "project.conventions"
      }
    ],
    "tooling.optional": [
      {
        "ref": "config.tooling"
      }
    ],
    "runtime.agents": [
      {
        "ref": "state.agents"
      }
    ]
  },
  "defaults": {
    "required": [
      {
        "ref": "framework.rules"
      },
      {
        "ref": "protocol.blocking_feedback"
      }
    ]
  },
  "commands": {
    "order.bootstrap": {
      "read_if_exists": [
        {
          "group": "project.contracts"
        },
        {
          "group": "runtime.agents"
        },
        {
          "ref": "state.bootstrap"
        },
        {
          "ref": "config.automation"
        }
      ],
      "required": [
        {"ref": "schema.bootstrap_state"},
        {"ref": "schema.active_feature_state"},
        {"ref": "schema.automation_config"}
      ]
    },
    "order.feature": {
      "required": [
        {"ref": "schema.active_feature_state"}
      ]
    },
    "order.spec": {
      "required": [
        {
          "group": "project.contracts"
        },
        {
          "ref": "framework.identifiers"
        }
      ]
    },
    "order.code-to-spec": {
      "required": [
        {
          "group": "project.contracts"
        },
        {
          "ref": "framework.identifiers"
        }
      ]
    },
    "order.spec-check": {
      "required": [
        {
          "group": "project.contracts"
        },
        {
          "ref": "framework.identifiers"
        }
      ],
      "feature_context": {
        "mode": "if_active",
        "artifacts": [
          "spec"
        ]
      }
    },
    "order.plan": {
      "required": [
        {
          "group": "project.contracts"
        },
        {
          "ref": "protocol.tooling"
        },
        {
          "ref": "protocol.environment_block"
        },
        {
          "ref": "framework.identifiers"
        }
      ],
      "read_if_exists": [
        {
          "group": "tooling.optional"
        }
      ],
      "feature_context": {
        "mode": "required",
        "artifacts": [
          "spec"
        ]
      }
    },
    "order.plan-check": {
      "required": [
        {
          "group": "project.contracts"
        },
        {
          "ref": "protocol.environment_block"
        },
        {
          "ref": "framework.identifiers"
        }
      ],
      "feature_context": {
        "mode": "if_active",
        "artifacts": [
          "spec",
          "plan"
        ]
      }
    },
    "order.tasks": {
      "required": [
        {
          "group": "project.contracts"
        },
        {
          "ref": "protocol.environment_block"
        },
        {
          "ref": "schema.task_context"
        },
        {
          "ref": "protocol.tooling"
        },
        {
          "ref": "framework.identifiers"
        }
      ],
      "read_if_exists": [
        {
          "group": "tooling.optional"
        }
      ],
      "feature_context": {
        "mode": "required",
        "artifacts": [
          "spec",
          "plan"
        ]
      }
    },
    "order.tasks-check": {
      "required": [
        {
          "group": "project.contracts"
        },
        {
          "ref": "protocol.environment_block"
        },
        {
          "ref": "schema.task_context"
        },
        {
          "ref": "framework.identifiers"
        }
      ],
      "feature_context": {
        "mode": "if_active",
        "artifacts": [
          "spec",
          "plan",
          "tasks"
        ]
      }
    },
    "order.code": {
      "required": [
        {
          "group": "project.contracts"
        },
        {
          "ref": "protocol.environment_block"
        },
        {
          "ref": "protocol.sub_agent_execution"
        },
        {
          "ref": "protocol.tooling"
        }
      ],
      "read_if_exists": [
        {
          "group": "tooling.optional"
        },
        {
          "ref": "config.automation"
        }
      ],
      "feature_context": {
        "mode": "if_active",
        "artifacts": [
          "tasks",
          "plan"
        ]
      }
    },
    "order.code-check": {
      "required": [
        {
          "group": "project.contracts"
        },
        {
          "ref": "framework.identifiers"
        }
      ],
      "feature_context": {
        "mode": "if_active",
        "artifacts": [
          "spec",
          "plan",
          "tasks"
        ]
      }
    }
  }
}
